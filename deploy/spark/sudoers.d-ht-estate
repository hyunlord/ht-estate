# ht-estate 배포 ops — scoped NOPASSWD (ops-sudo). 설치: /etc/sudoers.d/ht-estate (root:root 0440).
# **래퍼 한정**(ALL 아님) — hyunlord는 비번 없이 /usr/local/sbin/ht-estate-ctl 만 root로 실행.
# 래퍼는 **operate-ops 한정**(기존 ht-estate-* 유닛 restart/enable/status/logs/reload) — **유닛
# 설치 비포함**(새 root 유닛 내용 도입 불가 → escalation 0). 새 유닛은 install-root.sh(사용자 sudo).
# install-root.sh가 visudo -c 검증 통과 후에만 활성화(malformed로 sudo 락아웃 방지).
hyunlord ALL=(root) NOPASSWD: /usr/local/sbin/ht-estate-ctl
